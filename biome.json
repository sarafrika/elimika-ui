{
  "$schema": "https://biomejs.dev/schemas/2.3.6/schema.json",
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "suspicious": {
        "noConsole": "error",
        "noExplicitAny": "error"
      },
      "style": {
        "noNonNullAssertion": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "moment": "moment was removed for bundle size — use dayjs via '@/lib/date'.",
              "pdfjs-dist": "Load lazily via loadPdfjs() from '@/lib/pdfjs' — a static import adds ~2.5MB to the route bundle.",
              "pdfmake": "pdfmake was removed as unused — if needed again, dynamic-import it inside the click handler.",
              "@tanstack/react-query-devtools": "Only context/root-providers.tsx mounts devtools (dev-only, lazy).",
              "@/components/tiptap-templates/simple/simple-editor": "Import '@/components/tiptap-templates/simple/simple-editor-lazy' so the tiptap editor stays code-split."
            }
          }
        }
      },
      "correctness": {
        "noUnusedVariables": "off",
        "noUnusedImports": "off",
        "noUnusedPrivateClassMembers": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["lib/pdfjs.ts", "context/root-providers.tsx"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["scripts/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ],
  "files": {
    "includes": [
      "./**/*",
      "!node_modules",
      "!.next",
      "!.turbo",
      "!build",
      "!out",
      "!hey-client",
      "!app/globals.css",
      "!next-env.d.ts",
      "!services/api/schema.ts",
      "!services/client/**/*.gen.ts",
      "!services/client/client/**"
    ]
  }
}
