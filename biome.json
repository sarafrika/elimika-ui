{
  "$schema": "https://biomejs.dev/schemas/2.3.6/schema.json",
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "suspicious": {
        "noConsole": "error",
        "noExplicitAny": "warn"
      },
      "style": {
        "noNonNullAssertion": "off"
      },
      "correctness": {
        "noUnusedVariables": "off",
        "noUnusedImports": "off",
        "noUnusedPrivateClassMembers": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "src/features/profile/landing/**",
        "src/features/dashboard/courses/**",
        "src/features/profile/pages/student/StudentGuardianInformationPage.tsx",
        "src/features/profile/pages/instructor/InstructorCertificatesPage.tsx",
        "app/dashboard/_components/**",
        "app/dashboard/@student/_components/**",
        "app/class-invite/page.tsx",
        "app/dashboard/@admin/all-courses/**",
        "app/dashboard/@admin/programs/programs-page.tsx",
        "app/dashboard/@course_creator/course-management/**",
        "app/dashboard/@course_creator/profile/edit/page.tsx",
        "app/dashboard/@course_creator/profile/education/_component/EducationForm.tsx",
        "app/dashboard/@course_creator/profile/experience/_component/ExperienceForm.tsx",
        "app/dashboard/@course_creator/profile/general/_component/CourseCreatorProfile.tsx",
        "app/dashboard/@course_creator/profile/old-page.tsx",
        "app/dashboard/@course_creator/programs/page.tsx",
        "app/dashboard/@course_creator/programs/\\[id\\]/page.tsx",
        "app/dashboard/@course_creator/programs/create-new-program/page.tsx",
        "app/dashboard/@course_creator/programs/create-new-program/ProgramCourseManagement.tsx",
        "app/dashboard/@course_creator/programs/_components/ProgramList.tsx",
        "app/dashboard/@course_creator/analytics/page.tsx",
        "app/dashboard/@course_creator/enrollments/page.tsx",
        "app/dashboard/@course_creator/my-skills/page.tsx",
        "app/dashboard/@course_creator/notifications/page.tsx",
        "app/dashboard/@course_creator/revenue/page.tsx",
        "app/dashboard/@course_creator/rubrics/rubric-chaining.tsx",
        "app/dashboard/@course_creator/training-applications/_components/CoursesPage.tsx",
        "app/dashboard/@course_creator/training-applications/_components/InstructorDetailsModal.tsx",
        "app/dashboard/@course_creator/rubrics/rubric-manager.tsx",
        "app/dashboard/@instructor/assessment/assignments/assignment-list.tsx",
        "app/dashboard/@instructor/_components/class-management-form.tsx",
        "app/dashboard/@instructor/assessment/assignments/submissions.tsx",
        "app/dashboard/@course_creator/instructors/_comonent/InstructorPage.tsx",
        "app/dashboard/@instructor/apply-to-train/**",
        "app/dashboard/@course_creator/training-applications/_components/CourseDetails.tsx",
        "app/dashboard/@course_creator/training-applications/_components/TrainingApplicationsPage.tsx",
        "app/dashboard/@parent/all-courses/**",
        "app/dashboard/@student/skills-fund/page.tsx",
        "app/profile-user/public-user-profile.tsx",
        "app/dashboard/@admin/course-creators/_components/**",
        "app/dashboard/@admin/financial-overview/_component/**",
        "app/dashboard/@admin/instructors/_components/**",
        "types/pdfjs-dist.d.ts",
        "hooks/use-class-roster.ts",
        "hooks/use-instructor-classes-with-schedules.tsx",
        "hooks/use-student-class-definition.tsx",
        "hooks/use-quiz-details.ts",
        "hooks/use-instructor-classes.ts",
        "hooks/use-all-classes.ts",
        "hooks/use-studentsMap.tsx",
        "hooks/use-multi-mutations.tsx",
        "hooks/use-programlessonwithcontent.ts",
        "hooks/use-reverse-geocode.tsx",
        "hooks/use-throttled-callback.ts",
        "hooks/use-unmount.ts",
        "hooks/use-admin-classes.tsx",
        "hooks/use-course-classes.tsx",
        "hooks/use-program-classes.tsx",
        "hooks/use-search-training-instructors.tsx"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "error"
          }
        }
      }
    }
  ],
  "files": {
    "includes": [
      "./**/*",
      "!node_modules",
      "!.next",
      "!.turbo",
      "!build",
      "!out",
      "!hey-client",
      "!app/globals.css",
      "!next-env.d.ts",
      "!services/api/schema.ts",
      "!services/client/@tanstack/react-query.gen.ts"
    ]
  }
}
