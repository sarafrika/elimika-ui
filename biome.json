{
  "$schema": "https://biomejs.dev/schemas/2.3.6/schema.json",
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "suspicious": {
        "noConsole": "error",
        "noExplicitAny": "warn"
      },
      "style": {
        "noNonNullAssertion": "off"
      },
      "correctness": {
        "noUnusedVariables": "off",
        "noUnusedImports": "off",
        "noUnusedPrivateClassMembers": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "src/features/profile/landing/**",
        "src/features/dashboard/courses/**",
        "hooks/use-course-classes.tsx",
        "hooks/use-program-classes.tsx",
        "hooks/use-search-training-instructors.tsx"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "error"
          }
        }
      }
    }
  ],
  "files": {
    "includes": [
      "./**/*",
      "!node_modules",
      "!.next",
      "!.turbo",
      "!build",
      "!out",
      "!hey-client",
      "!app/globals.css",
      "!next-env.d.ts",
      "!services/api/schema.ts",
      "!services/client/@tanstack/react-query.gen.ts"
    ]
  }
}
